generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum TypeNotification {
  LIKE
  DISLIKE
  COMMENT
  REPLAY
  MESSAGE
  FOLLOW
}

// Models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                    String           @id @default(cuid())
  name                  String
  email                 String           @unique
  password              String?
  emailVerified         DateTime?        @map("email_verified")
  image                 String?
  role                  Role             @default(USER)
  headline              String?
  country               String?
  city                  String?
  school                String?
  imageProfile          String?
  accounts              Account[]
  sessions              Session[]
  posts                 Post[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  articles              Article[]
  comments              Comment[]
  likes                 Like[]
  disLikes              DisLike[]
  likeForComments       LikeForComment[]
  replays               Replay[]
  likeForReplays        LikeForReplay[]
  sentNotifications     Notification[]   @relation("ActorNotifications")
  receivedNotifications Notification[]   @relation("RecipientNotifications")
  saveItems             SaveItem[]
  followers             Follow[]         @relation("followers")
  following             Follow[]         @relation("following")

  @@map("users")
}

model Post {
  id            String         @id @default(cuid())
  contentText   String?
  image         String?
  video         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments      Comment[]
  likes         Like[]
  disLikes      DisLike[]
  replays       Replay[]
  notifications Notification[]
  saveItems     SaveItem[]
}

model Like {
  id String @id @default(cuid())

  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, postId])
}

model LikeForComment {
  id String @id @default(cuid())

  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, commentId])
}

model LikeForReplay {
  id String @id @default(cuid())

  userId   String
  replayId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  replay Replay @relation(fields: [replayId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, replayId])
}

model DisLike {
  id String @id @default(cuid())

  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, postId])
}

model Comment {
  id              String           @id @default(cuid())
  content         String
  postId          String
  userId          String
  isAuthor        Boolean          @default(false)
  isEdited        Boolean          @default(false)
  post            Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  likeForComments LikeForComment[]
  replays         Replay[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id],onDelete: Cascade)
  createAt    DateTime @default(now())

  @@unique([followerId, followingId])
}

model Replay {
  id             String          @id @default(cuid())
  content        String
  postId         String
  userId         String
  commentId      String
  isAuthor       Boolean         @default(false)
  isEdited       Boolean         @default(false)
  comment        Comment         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  likeForReplays LikeForReplay[]
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  userId    String
  slug      String   @unique
  image     String?
  video     String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id             String           @id @default(cuid())
  title          String
  body           String?
  route          String
  type           TypeNotification
  actorId        String
  actor          User             @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  postTitle      String?
  commentContent String?
  replayContent  String?
  recipientId    String
  recipient      User             @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  postId         String?
  post           Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId      String?
  replayId       String?
  createdAt      DateTime         @default(now())
  readAt         DateTime?
}

model SaveItem {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}